# ─────────────────────────────────────────────
#  PostgreSQL
# ─────────────────────────────────────────────
POSTGRES_USER=n8n
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_DB=n8n

# ─────────────────────────────────────────────
#  n8n
# ─────────────────────────────────────────────
# Generate a random 32-char string, e.g.:
#   openssl rand -hex 16
N8N_ENCRYPTION_KEY=your_random_encryption_key_here

# Hostname (use localhost for local dev)
N8N_HOST=localhost

# Timezone (https://momentjs.com/timezone/)
GENERIC_TIMEZONE=Asia/Jakarta
