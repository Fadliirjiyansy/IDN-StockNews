# =============================================================================
# Environment Variables — n8n + PostgreSQL
# =============================================================================
# Copy this file to .env and replace the placeholder values.
#   cp .env.example .env
#
# NEVER commit .env to version control (it's already in .gitignore).
# =============================================================================

# ---- PostgreSQL Credentials -------------------------------------------------
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

# ---- n8n Configuration -----------------------------------------------------
# Encryption key for stored credentials (generate with: openssl rand -hex 32)
N8N_ENCRYPTION_KEY=

# Host / Port / Protocol
N8N_HOST=
N8N_PORT=
N8N_PROTOCOL=

# Webhook base URL — set to your public domain in production
# Example: https://n8n.yourdomain.com
WEBHOOK_URL=

# Timezone
GENERIC_TIMEZONE=

# ---- Telegram Bot Configuration -------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- n8n Owner User ID (used for credential auto-import) -------------------
# Get from: docker exec financialreportnews-postgres psql -U n8n -d n8n -c 'SELECT id FROM "user" WHERE "roleSlug"='"'"'global:owner'"'"';'
N8N_OWNER_USER_ID=

# ---- Optional: Basic Auth (uncomment in docker-compose.yml to enable) -------
# N8N_BASIC_AUTH_USER=admin
# N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_basic_auth_password
